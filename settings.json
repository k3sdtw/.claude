{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit(**)",
      "Read(**)",
      "Write(**)",
      "Search(**)",
      "WebSearch",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(git reset*)",
      "Bash(rm -rf *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[언어 규칙] 이번 답변을 포함해 모든 사용자 대상 출력은 반드시 한국어로 작성한다. 코드·식별자·명령어·파일 경로·에러/로그 원문만 예외.'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/cc-chips/engine.sh"
  },
  "effortLevel": "xhigh",
  "fastMode": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
