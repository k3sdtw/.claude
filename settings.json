{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit(**)",
      "Read(**)",
      "Write(**)",
      "Search(**)",
      "WebSearch",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(git reset*)",
      "Bash(rm -rf *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/cc-chips/engine.sh"
  },
  "effortLevel": "xhigh",
  "fastMode": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
